# Banco local (SQLite) — não depende de nenhum serviço externo
DATABASE_URL="postgresql://sbx_db_user:48wzxZgniNt2e1jKDgCMT5XdNuFRbOmD@dpg-d90luthkh4rs739j171g-a.singapore-postgres.render.com/sbx_db"

# Porta da API
PORT=3001

# Segredo usado para assinar os tokens de login (gere um valor aleatório longo)
JWT_SECRET="troque-isto-por-um-segredo-bem-grande-e-aleatorio"

# Segredo combinado com a plataforma de pagamento, para validar o webhook de
# cadastro automático de usuários na assinatura aprovada
PAYMENT_WEBHOOK_SECRET="troque-isto-tambem"

# Chave usada pelo GitHub Actions (cron de 10 min) para chamar a sincronização
SYNC_API_KEY="troque-isto-por-outra-chave-aleatoria"

# IA usada para gerar texto e imagem dos anúncios.
# Texto: a Gemini API tem camada gratuita real (ver README). Sem chave, usa
# um gerador local por template.
GEMINI_API_KEY="AQ.Ab8RN6L5HqfJzNJRkNpLgw-tCMS0jaj4vQjkDjqA8-0UJCUKlg"

# Imagem: NÃO existe API de imagem totalmente gratuita em 2026 (ver README).
# A opção mais barata é o Imagen 4 Fast do Google (~US$0,02 por imagem),
# usando a mesma chave acima. Sem chave, o sistema não gera imagem (só texto).
ENABLE_IMAGE_GENERATION="true"

# URL pública desta API, usada pelo front-end e pela extensão em produção
PUBLIC_API_URL="http://localhost:3001"
